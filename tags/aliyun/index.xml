&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="nv">relase_time&lt;/span>&lt;span class="o">=&lt;/span>&lt;span class="k">$(&lt;/span>date --date&lt;span class="o">=&lt;/span>&lt;span class="s2">&amp;#34;@&lt;/span>&lt;span class="k">$(&lt;/span>date -d &lt;span class="s1">&amp;#39;+4 hours&amp;#39;&lt;/span> +%s&lt;span class="k">)&lt;/span>&lt;span class="s2">&amp;#34;&lt;/span> +&lt;span class="s1">&amp;#39;%Y-%m-%dT%H:%M:%SZ&amp;#39;&lt;/span> -u&lt;span class="k">)&lt;/span> &lt;span class="c1"># 获取4小时后的UTC时间&lt;/span>
