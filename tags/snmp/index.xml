<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Snmp on LeeCQ小空间</title><link>https://blog-g.leecq.cn/tags/snmp/</link><description>Recent content in Snmp on LeeCQ小空间</description><generator>Hugo -- gohugo.io</generator><language>zh-cn</language><lastBuildDate>Sat, 29 Oct 2022 00:00:00 +0000</lastBuildDate><atom:link href="https://blog-g.leecq.cn/tags/snmp/index.xml" rel="self" type="application/rss+xml"/><item><title>esxi snmp 配置</title><link>https://blog-g.leecq.cn/p/yujunshu-2/</link><pubDate>Sat, 29 Oct 2022 00:00:00 +0000</pubDate><guid>https://blog-g.leecq.cn/p/yujunshu-2/</guid><description>&lt;h1 id="esxi-snmp-配置">esxi snmp 配置
&lt;/h1>&lt;p>esxi 详细文档设置&lt;a class="link" href="https://docs.vmware.com/cn/VMware-vSphere/index.html" target="_blank" rel="noopener"
>VMware vSphere 文档&lt;/a>&lt;/p>
&lt;h2 id="开启-snmp">开启 snmp
&lt;/h2>&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;span class="lnt">2
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-fallback" data-lang="fallback">&lt;span class="line">&lt;span class="cl">esxcli system snmp set --communities public,private
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">esxcli system snmp set --enable true
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h2 id="配置轮询的-snmp-代理">配置轮询的 SNMP 代理
&lt;/h2>&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-shell" data-lang="shell">&lt;span class="line">&lt;span class="cl">esxcli system snmp &lt;span class="nb">set&lt;/span> --port &lt;span class="m">1600&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div></description></item></channel></rss>